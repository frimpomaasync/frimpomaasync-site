# Clean URLs for frimpomaasync.com — lives in the GitHub repo, auto-deployed.
Options -MultiViews
RewriteEngine On

# NanaOS app folder: leave every URL exactly as-is
RewriteCond %{REQUEST_URI} ^/os-fad13324c3/ [NC]
RewriteRule ^ - [L]

# Retired: Som used to ship as a zip. Anyone holding that link from an older
# email lands on the app instead of a 404.
RewriteRule ^Som\.zip$ /som-app/ [R=301,L,NC]

# /index.html -> /
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# /page.html -> /page  (permanent, keeps query strings)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# /page -> serve page.html  (internal, invisible)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
